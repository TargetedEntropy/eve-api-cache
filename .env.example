REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://localhost/eve_cache
ESI_BASE_URL=https://esi.evetech.net
USER_AGENT=eve-api-cache/0.1 (https://github.com/TargetedEntropy/eve-api-cache)
ESI_TIMEOUT=30.0
ESI_MAX_RETRIES=2
ESI_RETRY_BASE_DELAY=0.25
PAGE_CONCURRENCY=10
UPSTREAM_CONCURRENCY=20
DEFAULT_DATASOURCE=tranquility
MAX_POST_BODY_BYTES=65536
MAX_POST_BATCH_ITEMS=1000
STALE_CACHE_SECONDS=86400
CLIENT_RATE_LIMIT_PER_MINUTE=600
COLLECTOR_ENABLED=true

# Collector — background proactive polling
# Comma-separated region IDs to backfill market data for.
# Defaults are the 5 major trade hubs: The Forge (Jita), Domain (Amarr),
# Heimatar (Rens), Sinq Laison (Dodixie), Metropolis (Hek).
MARKET_REGION_IDS=[10000002,10000043,10000030,10000032,10000042]
POLL_MARKET_ORDERS_SECONDS=300
POLL_MARKET_PRICES_SECONDS=3600
POLL_MARKET_HISTORY_SECONDS=86400
POLL_UNIVERSE_SECONDS=3600
